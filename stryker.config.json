{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "_comment": "Mutation testing focused on the pure engine — the part with real logic worth verifying.",
  "packageManager": "pnpm",
  "testRunner": "vitest",
  "plugins": ["@stryker-mutator/vitest-runner"],
  "reporters": ["html", "clear-text", "progress"],
  "coverageAnalysis": "perTest",
  "mutate": ["src/lib/engine/**/*.ts", "!src/lib/engine/units.ts", "!src/lib/engine/worker.ts"],
  "vitest": {
    "configFile": "vite.config.ts"
  },
  "thresholds": { "high": 85, "low": 70, "break": 50 }
}
